# --- LLM (pick one key; NVIDIA key takes precedence if both are set) ---
# OpenAI (default base URL)
OPENAI_API_KEY=

# NVIDIA (same as: OpenAI(base_url="https://integrate.api.nvidia.com/v1", api_key=...))
NVIDIA_API_KEY=
# Optional override (include /v1, or use host only—e.g. https://integrate.api.nvidia.com—we append /v1)
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Default chat model (also used when the Decision Room omits model if you set NEXT_PUBLIC_DEFAULT_MODEL)
LLM_DEFAULT_MODEL=stepfun-ai/step-3.5-flash
# Optional multi-tier routing (omit both to use the request model everywhere):
# LLM_DEBATE_MODEL=provider/cheap-model    # classic turns + interjections; swarm JSON turns
# LLM_SYNTH_MODEL=provider/strong-model    # closing JSON, votes, Chief Synthesizer report

# Completion knobs: temperature=1, top_p=1, max_tokens=16384
LLM_TEMPERATURE=1
LLM_TOP_P=1
LLM_MAX_TOKENS=16384
# Model context length (tokens); used to cap max_tokens so prompt + completion fits. Default 8192 is safe for 8k models.
# LLM_CONTEXT_TOKENS=131072
# NVIDIA “thinking” / reasoning channel (extra_body). Default is off; set true only if you want reasoning traces.
# NVIDIA_ENABLE_THINKING=false

# Some models (e.g. Gemma on NVIDIA) reject role=system; auto-merge into user. Override: true / false
# LLM_MERGE_SYSTEM_INTO_USER=

# API (production) — comma-separated browser origins allowed to call the API (Vercel URL, custom domain)
# CORS_ORIGINS=https://your-app.vercel.app,https://www.example.com

# JWT signing for username/password auth (required in production; defaults for local dev only)
# JWT_SECRET=
# JWT_ALGORITHM=HS384
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Guest demo (POST /auth/guest) — enabled by default in local dev
# GUEST_AUTH_ENABLED=true
# GUEST_TOKEN_EXPIRE_MINUTES=240
# Cloudflare Turnstile (captcha for Try demo). Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
# TURNSTILE_SECRET_KEY=
# GUEST_CAPTCHA_BYPASS=true

# PostgreSQL (required). User, password, host, port, and database name must match your server.
# Local + bundled DB (from repo root: docker compose up db). Host port is 5435 → container 5432:
#   DATABASE_URL=postgresql://hiivbuddy:hiivbuddy@localhost:5435/hiivbuddy
# If you see "password authentication failed for user hiivbuddy", either start that Compose service
# or change DATABASE_URL to your real Postgres user/password (and create the database first).
# Render: link a Postgres instance — Render injects DATABASE_URL (postgresql://...).
DATABASE_URL=

# Docker Compose: host port for the `web` service (change if 3000 is already in use on your machine).
# WEB_HOST_PORT=3001

# Decision Room default session mode: **`swarm`** unless set to `classic` (structured JSON vs streamed debate).
# NEXT_PUBLIC_DEFAULT_SESSION_MODE=classic

# Web (Next.js) — browser calls the API directly from your machine
NEXT_PUBLIC_API_URL=http://localhost:8000
# Turnstile site key (public) — must match TURNSTILE_SECRET_KEY on the API
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Optional: default model shown in Decision Room (mirror LLM_DEFAULT_MODEL or leave unset)
# NEXT_PUBLIC_DEFAULT_MODEL=stepfun-ai/step-3.5-flash
